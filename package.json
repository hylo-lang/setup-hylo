{
  "name": "setup-hylo",
  "version": "0.0.1",
  "description": "GitHub action that installs the Hylo toolchain at an explicit release tag and exposes the `hc` compiler on PATH.",
  "repository": {
    "type": "git",
    "url": "https://github.com/hylo-lang/setup-hylo"
  },
  "author": "Ambrus Tóth",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf ./build ./dist",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "pack": "npm run lint && npm run build && ncc build build/src/action.js -o dist",
    "test": "npm run pack && jest"
  },
  "devDependencies": {
    "@types/jest": "^29.2.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vercel/ncc": "^0.38.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^29.0.0",
    "jest": "^29.2.1",
    "jest-circus": "^29.7.0",
    "ts-jest": "^29.0.3",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@actions/cache": "^4.0.3",
    "@actions/core": "^1.10.0",
    "@actions/io": "^1.1.2",
    "@actions/tool-cache": "^2.0.1"
  }
}
